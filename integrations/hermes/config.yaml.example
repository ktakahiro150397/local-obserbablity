# hermes-otel configuration template for backup-secretary
#
# Copy this file into each Hermes instance's hermes_otel plugin directory as
# config.yaml. Keep instance-specific values local or generate them during the
# backup-secretary image/config deployment.
#
# Reviewed against hermes-otel 0.11.0 / commit:
#   0180c5e63b9d035ee0754d9a0d75c3499a8def26
# Re-check compatibility before implementation and pin the selected version.

# hermes-otel uses project_name as the OTel service.name.
project_name: backup-secretary-hermes

resource_attributes:
  service.namespace: backup-secretary
  # Set to `main` or `owashota` for each instance.
  service.instance.id: <HERMES_INSTANCE_ID>
  deployment.environment: home

# Phase 1 privacy policy: retain operational metadata and Discord sender ID,
# but never export conversation or tool payloads.
capture_previews: false
capture_conversation_history: false
capture_sender_id: true
capture_logs: false

emit_genai_metrics: true
force_flush_on_session_end: true

backends:
  - type: lgtm
    # Replace the host with the actual Compose service name on the shared
    # external Docker network. This endpoint is internal to Docker and should
    # not contain a public address.
    endpoint: http://otel-lgtm:4318/v1/traces
    traces: true
    metrics: true
    logs: false
