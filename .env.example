# Copy to .env with scripts/init-local-env.sh on the target local server.
# Never commit the generated .env or the data directories.

PRIVATE_DATA_DIR=/home/<SERVER_USER>/local-observability-data/private
SHARED_DATA_DIR=/home/<SERVER_USER>/local-observability-data/shared
LGTM_UID_GID=1000:1000
CLOUDFLARED_UID_GID=1000:1000

# Keep both Grafana origins localhost-only. Use SSH forwarding for owner access.
PRIVATE_GRAFANA_BIND=127.0.0.1
PRIVATE_GRAFANA_PORT=3002
PRIVATE_GRAFANA_ROOT_URL=http://localhost:3002
SHARED_GRAFANA_BIND=127.0.0.1
SHARED_GRAFANA_PORT=3003

# The example is safe by default. The initializer writes the detected trusted
# LAN address into the ignored real .env; do not start the router until H9.
OTLP_HTTP_BIND=127.0.0.1
OTLP_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133

PRIVATE_GRAFANA_ADMIN_USER=admin
PRIVATE_GRAFANA_ADMIN_PASSWORD=<GENERATED_LOCAL_SECRET>
PRIVATE_GRAFANA_SECRET_KEY=<GENERATED_LOCAL_SECRET>
SHARED_GRAFANA_ADMIN_USER=breakglass
SHARED_GRAFANA_ADMIN_PASSWORD=<GENERATED_LOCAL_SECRET>
SHARED_GRAFANA_SECRET_KEY=<GENERATED_LOCAL_SECRET>

# Initial retention is deliberately conservative and must be revisited after a week.
PROMETHEUS_EXTRA_ARGS=--storage.tsdb.retention.time=30d
TEMPO_EXTRA_ARGS=

# Initial resource limits for the inventoried 8 GiB target server.
PRIVATE_LGTM_MEMORY_LIMIT=3000m
SHARED_LGTM_MEMORY_LIMIT=1800m
OTEL_ROUTER_MEMORY_LIMIT=384m
CLOUDFLARED_MEMORY_LIMIT=128m
PRIVATE_LEDGER_MEMORY_LIMIT=384m
SHARED_LEDGER_MEMORY_LIMIT=384m
PRIVATE_LGTM_CPU_LIMIT=1.5
SHARED_LGTM_CPU_LIMIT=1.5
OTEL_ROUTER_CPU_LIMIT=0.5
CLOUDFLARED_CPU_LIMIT=0.25
PRIVATE_LEDGER_CPU_LIMIT=0.5
SHARED_LEDGER_CPU_LIMIT=0.5
