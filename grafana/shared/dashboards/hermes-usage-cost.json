          "rawSql": "SELECT COALESCE(NULLIF(model_id, ''), '(model missing)') AS \"Unpriced model\", SUM(total_tokens)::bigint AS \"Unpriced tokens\", unpriced_reason AS \"Reason\" FROM grafana.hermes_usage_dashboard WHERE NOT pricing_matched AND source_instance ~ '^(${instance:regex})$' AND $__timeFilter(event_time) GROUP BY COALESCE(NULLIF(model_id, ''), '(model missing)'), unpriced_reason ORDER BY \"Unpriced tokens\" DESC;",
