            "type": "grafana-postgresql-datasource",
            "uid": "hermes-usage-ledger"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN COALESCE(SUM(total_tokens), 0) = 0 THEN 100.000 ELSE TRUNC(100.0 * SUM(CASE WHEN pricing_matched THEN total_tokens ELSE 0 END) / SUM(total_tokens), 3) END::double precision AS \"Pricing coverage\" FROM grafana.hermes_usage_dashboard WHERE source_instance ~ '^(${instance:regex})$' AND $__timeFilter(event_time);",
          "refId": "A"
        }
      ],
      "title": "Pricing coverage",
      "type": "stat"
