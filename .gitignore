# Local environment and secrets
.env
.env.*
!.env.example
*.local
*.local.*
*.secret
secrets/

# Machine-specific notes
notes/
**/environment.local.md
inventory.local.*
verification.local.*

# Cloudflare local credentials/configuration
cloudflare/config.yml
cloudflare/config.yaml
cloudflare/*.json
cloudflare/*.pem
cloudflare/*.key
cloudflare/*.token

# Runtime and telemetry data
data/
runtime/
telemetry-data/
*.db
*.sqlite
*.sqlite3

# Historical backfill source data and local reports
backfill/snapshots/
backfill/staging/
backfill/manifests/
backfill/reports/
backfill/*.local.*
backfill/coverage.local.*
backfill/cutovers.local.*

# Grafana local state / exports / configuration
grafana-data/
exports/
backups/
grafana/**/grafana.ini

# Local identity mappings
user-aliases.*
users.local.*
grafana/**/users.local.*
grafana/**/discord-user-map.*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and temp
*.log
tmp/
.temp/
